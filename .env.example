# .env.example - Образец настроек для HobbyHold
# Скопируйте этот файл в .env и замените значения на свои!

# REQUIRED — app will not start without these

# Настройки безопасности приложения (генерируются случайно)
# Можно сгенерировать командой: openssl rand -hex 32
SECRET_KEY=измените_на_длинную_секретную_строку

# Настройки базы данных PostgreSQL
POSTGRES_USER=hobby_user
POSTGRES_PASSWORD=надежный_пароль_здесь
POSTGRES_DB=hobbyhold

# URL для SQLAlchemy (используется приложением и Alembic)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_PASSWORD=надежный_пароль_redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# S3 Object Storage Settings
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hobbyhold
S3_PUBLIC_URL=http://localhost:9000/hobbyhold
